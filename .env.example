# Copy to `.env` for local dev. Vite only exposes variables prefixed with `VITE_`.
# For production, set the same keys in EdgeOne build settings.

# --- Tencent CloudBase (frontend) ---
VITE_CLOUDBASE_ENV_ID=nexa-mm-i0goiaxufc1521e43
VITE_CLOUDBASE_REGION=ap-shanghai
VITE_CLOUDBASE_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/functions/make-server-16010b6f
VITE_CLOUDBASE_PUBLISHABLE_KEY=
VITE_CLOUDBASE_THUMB_MAX=480
VITE_VENDOR_SUBDOMAIN_BASE_DOMAIN=nexa-apex.online
# Comma-separated marketplace apex hosts (branding landing at /). Add every production
# apex you point at EdgeOne, e.g. nexa-mm.com when www works but apex does not until DNS is fixed.
VITE_PLATFORM_RESERVED_APEX_DOMAINS=nexa-mm.com,nexa-apex.online
VITE_DEPLOYMENT_PLATFORM=edgeone

# --- TencentDB (schema migration + Supabase import scripts) ---
# URL-encode special characters in passwords. Managed TencentDB often uses a custom port (e.g. 23100).
# TENCENT_DATABASE_URL=postgresql://user:PASSWORD@sg-postgres-xxxx.sql.tencentcdb.com:23100/postgres
# SOURCE_POSTGRES_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# --- CloudBase function env (set in TCB console, see cloudbase/function-env.template.env) ---
# CLOUDBASE_ENV_ID=nexa-mm-i0goiaxufc1521e43
# CLOUDBASE_SERVICE_TOKEN=
# CLOUDBASE_PUBLISHABLE_KEY=
# CLOUDBASE_API_BASE_URL=
# EDGE_ADMIN_OPERATION_SECRET=
# TENCENT_POSTGREST_URL=   # auto-defaults from CLOUDBASE_ENV_ID when unset on function

# --- Admin destructive operations (optional) ---
# VITE_ADMIN_OPERATION_SECRET=

# --- Payments (optional) ---
# VITE_STRIPE_PUBLISHABLE_KEY=

# Quick start (empty DB + function zips):
#   npm run setup:tcb-first
# Console guide:
#   docs/TCB_CONSOLE_SETUP.md
# Import Supabase data (excludes kpay txn/draft + chat):
#   npm run import:supabase-data
# Test DB connections:
#   npm run test:db
