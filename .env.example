# Copy to `.env` for local dev. Vite only exposes variables prefixed with `VITE_`.
# For production, set the same keys in your host’s dashboard (Vercel, Netlify, etc.).

# --- Tencent CloudBase / TencentDB (IMPORTANT) ---
# The browser API client calls this CloudBase HTTP Function base URL.
# For same-origin CloudBase Hosting rewrites, the default /api/make-server-16010b6f is fine.
# VITE_CLOUDBASE_ENV_ID=your-cloudbase-env-id
# VITE_CLOUDBASE_REGION=ap-shanghai
# VITE_CLOUDBASE_API_BASE_URL=https://your-api-domain.example.com/make-server-16010b6f
# VITE_CLOUDBASE_PUBLISHABLE_KEY=
# VITE_CLOUDBASE_THUMB_MAX=480
#
# Server-side CloudBase Function env:
# CLOUDBASE_API_BASE_URL=https://your-api-domain.example.com/make-server-16010b6f
# CLOUDBASE_PUBLISHABLE_KEY=
# CLOUDBASE_SERVICE_TOKEN=
# TENCENT_POSTGREST_URL=https://your-postgrest-or-tencentdb-rest.example.com
# TENCENT_POSTGREST_SERVICE_KEY=
# CLOUDBASE_AUTH_API_BASE_URL=https://your-auth-adapter.example.com
# CLOUDBASE_STORAGE_API_BASE_URL=https://your-storage-adapter.example.com

# --- Platform apex / vendor subdomains ---
# Apex domain only, no protocol. KBZPay PWA returns to https://<apex>/summary.
# VITE_VENDOR_SUBDOMAIN_BASE_DOMAIN=nexa-mm.com
# VITE_PLATFORM_RESERVED_APEX_DOMAINS=nexa-mm.com,www.nexa-mm.com

# JSON map: short DNS label → real store slug in /vendor/:slug
# Example: {"gogo":"go-go","myshop":"my-shop"}
# VITE_VENDOR_SUBDOMAIN_SLUG_MAP={}

# Optional local subdomain checkout (e.g. http://gogo.localhost:5173/checkout → /summary):
# VITE_VENDOR_SUBDOMAIN_BASE_DOMAIN=localhost

# --- Admin destructive operations (optional) ---
# Must match EDGE_ADMIN_OPERATION_SECRET on the CloudBase server.
# VITE_ADMIN_OPERATION_SECRET=

# --- Payments (optional / not in live vendor checkout) ---
# VITE_STRIPE_PUBLISHABLE_KEY=

# Vercel Edge middleware (server env, not VITE_ — set in Vercel project settings):
# VENDOR_SUBDOMAIN_BASE_DOMAIN=nexa-mm.com
# PLATFORM_RESERVED_APEX_DOMAINS=nexa-mm.com,www.nexa-mm.com
# VENDOR_SUBDOMAIN_SLUG_MAP={"gogo":"go-go"}

# CloudBase Function secrets:
# KBZPay gateway credentials, EDGE_ADMIN_OPERATION_SECRET, STRIPE_SECRET_KEY (optional)
# KPAY_PWA_FRONTEND_RETURN_URL=https://nexa-mm.com
# PLATFORM_RESERVED_APEX_DOMAINS=nexa-mm.com,www.nexa-mm.com
# VENDOR_SUBDOMAIN_BASE_DOMAIN=nexa-mm.com
#
# Tencent EdgeOne only (leave unset on Vercel — keeps cname.vercel-dns.com behavior):
# DEPLOYMENT_PLATFORM=edgeone
# CUSTOM_DOMAIN_CNAME_TARGET=   # optional project-wide hint; usually leave empty (per-domain CNAME in EdgeOne console)
#
# Vite (EdgeOne project env — auto-detected on *.edgeone.dev without this):
# VITE_DEPLOYMENT_PLATFORM=edgeone
# VITE_CUSTOM_DOMAIN_CNAME_TARGET=   # optional; usually leave empty
