# CloudBase function environment variables (TCB console -> Cloud Function -> Environment variables)
# Replace placeholders before deploying make-server-16010b6f and kpay-webhook.

# --- Required: link TencentDB in TCB console first (Relational Database) ---
CLOUDBASE_ENV_ID=nexa-mm-i0goiaxufc1521e43
CLOUDBASE_REGION=ap-shanghai

# Auto-resolved when unset if CLOUDBASE_ENV_ID is set (PostgREST-compatible RDB REST):
# TENCENT_POSTGREST_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/rdb/rest

# Use Server API Key from TCB console (API Key Configuration -> Create API Key)
CLOUDBASE_SERVICE_TOKEN=
TENCENT_POSTGREST_SERVICE_KEY=

# Client publishable key (same as VITE_CLOUDBASE_PUBLISHABLE_KEY)
CLOUDBASE_PUBLISHABLE_KEY=

# Public API base (HTTP Gateway URL ending in /make-server-16010b6f)
CLOUDBASE_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/functions/make-server-16010b6f

# Auth uses CloudBase /auth/v1 when CLOUDBASE_ENV_ID is set (enable username/password in TCB Authentication)
# CLOUDBASE_AUTH_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/auth/v1

# Storage: enable Cloud Storage in TCB console; uploads use service token via HTTP API
# CLOUDBASE_STORAGE_API_BASE_URL=

# Admin destructive routes + diagnostics
EDGE_ADMIN_OPERATION_SECRET=

# Optional: KBZPay (only if testing payments)
# KPAY_* secrets from your gateway
