# CloudBase function environment variables (TCB console -> Cloud Function -> Environment variables)
# Replace placeholders before deploying make-server-16010b6f and kpay-webhook.

# --- Required: link TencentDB in TCB console first (Relational Database) ---
CLOUDBASE_ENV_ID=nexa-mm-i0goiaxufc1521e43
CLOUDBASE_REGION=ap-shanghai

# Auto-resolved when unset if CLOUDBASE_ENV_ID is set (PostgREST-compatible RDB REST):
# TENCENT_POSTGREST_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/rdb/rest

# Use Server API Key from TCB console (API Key Configuration -> Create API Key)
CLOUDBASE_SERVICE_TOKEN=
TENCENT_POSTGREST_SERVICE_KEY=

# Client publishable key (same as VITE_CLOUDBASE_PUBLISHABLE_KEY)
CLOUDBASE_PUBLISHABLE_KEY=

# Public API base (HTTP Gateway URL ending in /make-server-16010b6f)
CLOUDBASE_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/functions/make-server-16010b6f

# Same URL as VITE_CLOUDBASE_API_BASE_URL — used for KV storage signed image URLs
CLOUDBASE_API_PUBLIC_BASE_URL=https://nexa-mm-i0goiaxufc1521e43-1446771428.ap-singapore.app.tcloudbase.com/make-server-16010b6f

# Auth uses CloudBase /auth/v1 when CLOUDBASE_ENV_ID is set (enable username/password in TCB Authentication)
# CLOUDBASE_AUTH_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/auth/v1

# Image/file storage (see docs/ARCHITECTURE_AND_BACKEND.md § Image and file storage):
# - DEFAULT (NEXA production): leave CLOUDBASE_STORAGE_API_BASE_URL unset.
#   Uploads compress client-side (~500KB) and store in TencentDB KV (storage:obj:* keys).
#   Requires CLOUDBASE_API_PUBLIC_BASE_URL below for browser-visible signed URLs.
# - OPTIONAL: set to CloudBase PG Storage HTTP API base to store bytes in object storage instead, e.g.:
#   CLOUDBASE_STORAGE_API_BASE_URL=https://nexa-mm-i0goiaxufc1521e43.api.intl.tcloudbasegateway.com/v1/storages
# CLOUDBASE_STORAGE_API_BASE_URL=

# Admin destructive routes + diagnostics
EDGE_ADMIN_OPERATION_SECRET=

# =============================================================================
# Email (Tencent SES) — password reset OTP + future welcome emails
# Console: https://console.cloud.tencent.com/ses — verify sender domain + address first.
# Create API keys: https://console.cloud.tencent.com/cam/capi
# =============================================================================
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
# SES region (defaults to CLOUDBASE_REGION, then ap-singapore)
TENCENT_SES_REGION=ap-singapore
# Verified sender in SES console (plain email only, not display name):
TENCENT_SES_FROM_EMAIL=noreply@your-verified-domain.com
TENCENT_SES_FROM_NAME=Nexa Marketplace
# Approved SES template for password reset (Configuration -> Email Template in SES console)
TENCENT_SES_PASSWORD_RESET_TEMPLATE_ID=70882
# Must match {{variable}} name in the template body (default: otp_code)
# TENCENT_SES_TEMPLATE_OTP_VAR=otp_code
# Optional reply-to for bounces/replies
# TENCENT_SES_REPLY_TO=support@your-verified-domain.com

# =============================================================================
# KBZPay (KPay) — copy values from Supabase Edge Function secrets, then update
# the two TCB-specific URLs below. Set on BOTH make-server-16010b6f and kpay-webhook
# (kpay-webhook only needs KPAY_SIGN_KEY + the CLOUDBASE_* / TENCENT_* vars above).
# =============================================================================

# --- Required for QR + PWA checkout (make-server-16010b6f) ---
KPAY_PROXY_BASE_URL=
KPAY_APPID=
KPAY_MERCH_CODE=
KPAY_SIGN_KEY=

# KBZ server-to-server callback — MUST point at TCB kpay-webhook (not Supabase).
# Example: https://nexa-mm-i0goiaxufc1521e43.api.tcloudbasegateway.com/v1/functions/kpay-webhook
KPAY_NOTIFY_URL=

# After KBZ hits GET /kpay/pwa/return on make-server, redirect customer here.
# Example: https://nexa-apex.online/summary  (unified apex post-payment page)
KPAY_PWA_FRONTEND_RETURN_URL=

# prod | uat — controls PWA redirect host (wap.kbzpay.com vs static.kbzpay.com/uat)
KPAY_ENV=prod

# --- Proxy auth (only if your KBZ relay gates inbound traffic, e.g. VPS proxy) ---
# KPAY_PROXY_AUTH_HEADER=Authorization
# KPAY_PROXY_AUTH_SCHEME=Bearer
# KPAY_PROXY_AUTH_TOKEN=

# --- ISV / sub-merchant (set if Supabase had these) ---
# KPAY_SUB_MERCH_CODE=
# KPAY_SUB_APPID=
# KPAY_ISV_TRANS_TYPE=OnlinePaymentISV

# --- PWA-specific credentials (optional; fall back to KPAY_* above) ---
# KPAY_PWA_APPID=
# KPAY_PWA_MERCH_CODE=
# KPAY_PWA_SIGN_KEY=
# KPAY_PWA_SUB_MERCH_CODE=
# KPAY_PWA_SUB_APPID=

# --- Refunds via VPS proxy (optional) ---
# KBZ_VPS_REFUND_URL=
# KBZ_VPS_API_SECRET=
# KPAY_USE_VPS_REFUND=1

# --- PWA orphan draft cron (optional; can reuse EDGE_ADMIN_OPERATION_SECRET) ---
# KPAY_PWA_RECONCILE_SECRET=

# --- UAT only: accept unsigned webhook in sandbox (NEVER in production) ---
# KPAY_WEBHOOK_UAT_TRUST_NOTIFY=1
