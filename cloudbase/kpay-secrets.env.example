# Copy to cloudbase/kpay-secrets.env (gitignored) and fill values from your
# original source — Supabase dashboard CANNOT show secret values (SHA256 only).
#
# Paste ANY names you have from Supabase (including duplicates like KPAY_SECRET
# and KPAY_SIGN_KEY). Run: npm run kpay:prepare-tcb-env
#
# Typical sources for the actual values:
#   - Old .env used with: supabase secrets set --env-file .env
#   - Password manager / team vault
#   - KBZ merchant portal / VPS proxy config

# --- Aliases OK — script keeps canonical names only ---
KPAY_PROXY_BASE_URL=
KPAY_BASE_URL=
KPAY_APPID=
KPAY_APP_ID=
KPAY_MERCH_CODE=
KPAY_MERCHANT_ID=
KPAY_SIGN_KEY=
KPAY_SECRET=
KPAY_ENV=prod
KPAY_NOTIFY_URL=
KPAY_PWA_FRONTEND_RETURN_URL=

# Paths (only if non-default)
# KPAY_PATH_CREATE_QR=
# KPAY_CREATE_QR_PATH=
# KPAY_PATH_QUERY_ORDER=
# KPAY_QUERY_ORDER_PATH=

# Proxy auth (VPS relay)
# KPAY_PROXY_AUTH_HEADER=
# KPAY_PROXY_AUTH_SCHEME=
# KPAY_PROXY_AUTH_TOKEN=

# ISV / sub-merchant
# KPAY_SUB_MERCH_CODE=
# KPAY_PWA_APPID=
# KPAY_PWA_MERCH_CODE=
# KPAY_PWA_SIGN_KEY=

# Refunds (optional)
# KBZ_VPS_REFUND_URL=
# KBZ_VPS_API_SECRET=
