{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/store", "destination": "/", "permanent": true },
    { "source": "/products", "destination": "/", "permanent": true },
    { "source": "/products/:path*", "destination": "/", "permanent": true },
    {
      "source": "/product/:path*",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/product/:path*",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/profile/:path*",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/profile/:path*",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/profile",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/profile",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/saved",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/saved",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    { "source": "/blog/:path*", "destination": "/", "permanent": true },
    { "source": "/blog", "destination": "/", "permanent": true },
    {
      "source": "/checkout/:path*",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/checkout/:path*",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/checkout",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/checkout",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/order-confirmation",
      "has": [{ "type": "host", "value": "nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/order-confirmation",
      "has": [{ "type": "host", "value": "www.nexa-mm.com" }],
      "destination": "/",
      "permanent": true
    },
    { "source": "/store/reset-password", "destination": "/reset-password", "permanent": true },
    { "source": "/store/:slug/reset-password", "destination": "/vendor/:slug/reset-password", "permanent": true },
    { "source": "/store/:path*", "destination": "/vendor/:path*", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/.well-known/migoo-verify.txt",
      "destination": "/api/migoo-challenge"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
